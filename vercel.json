{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "cd dashboard && npm install && npm run build",
  "outputDirectory": "dashboard/dist",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "functions": {
    "api/dashboard.js": {
      "memory": 1024,
      "maxDuration": 60
    },
    "api/vehicles.js": {
      "memory": 1024,
      "maxDuration": 60
    },
    "api/crm.js": {
      "memory": 1024,
      "maxDuration": 60
    }
  }
}
